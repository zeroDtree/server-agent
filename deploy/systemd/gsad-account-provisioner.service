[Unit]
Description=GSAD account provisioner
Documentation=file:@REPO_ROOT@/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@REPO_ROOT@/account-provisioner
EnvironmentFile=-@REPO_ROOT@/deploy/env/common.env
EnvironmentFile=-@REPO_ROOT@/deploy/env/provisioner.env
ExecStart=@UV_BIN@ run python provision_loop.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
