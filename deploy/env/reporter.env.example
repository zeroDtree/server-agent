# GPU server report settings (installed to /etc/gsad-agent/reporter.env)

# Upstream report API base URL (defaults to GSAD_API_URL from common.env when unset)
# REPORT_API_URL=http://localhost:8080

# Report interval in seconds (minimum 5)
AGENT_REPORT_INTERVAL=30

# Resource label sent as resourceLevel (optional; auto-detected from nvidia-smi)
# AGENT_RESOURCE_LEVEL=NVIDIA H100

# Metrics HTTP server (--serve only; separate from health port)
# AGENT_HTTP_HOST=0.0.0.0
# AGENT_HTTP_PORT=9090

# Localhost health endpoint (0 = disabled)
AGENT_HEALTH_HOST=127.0.0.1
AGENT_HEALTH_PORT=9092
