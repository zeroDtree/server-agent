# Account provisioner settings (installed to /etc/gsad-agent/provisioner.env)

# Poll interval in seconds (minimum 5)
PROVISION_POLL_INTERVAL=30

# Path to isolation scripts (default under install dir)
# ISOLATION_DIR=/opt/gsad-agent/account-provisioner/isolation

# Absolute data root for add-user.sh / remove-user.sh
DATA_ROOT=/data

# SSH-reachable IP on successful grant (recommended in production)
# Falls back to: netbird status --ipv4
# PROVISION_SERVER_IP=100.67.138.168

# NetBird CLI (default: netbird in PATH)
# NETBIRD_BIN=netbird

# Use sudo -n when not root (1 = yes, 0 = no)
PROVISION_USE_SUDO=1

# Dry run: log only, no scripts or complete callbacks (1 = yes)
# PROVISION_DRY_RUN=0

# Localhost health endpoint (0 = disabled)
AGENT_HEALTH_HOST=127.0.0.1
AGENT_HEALTH_PORT=9091
