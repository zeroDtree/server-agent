# Shared agent settings (deploy/env/common.env in this repo)
# Used by both account-provisioner and gpu-server-report.
# install.sh sets UPSTREAM_API_URL from REPORT_API_URL for account-provisioner.

# Report API base URL (no trailing slash)
REPORT_API_URL=http://localhost:8080

# Agent pre-shared key (required; must match server configuration)
AGENT_PSK=change-me-in-production

# Required. Server id (sent as JSON serverId)
AGENT_SERVER_ID=gpu-node-01
