# Shared GSAD agent settings (installed to /etc/gsad-agent/common.env)
# Used by both account-provisioner and gpu-server-report.

# GSAD API base URL (no trailing slash)
GSAD_API_URL=http://localhost:8080

# Agent pre-shared key (required; must match gsad AGENT_PSK)
AGENT_PSK=change-me-in-production

# Must match gsad t_server.server_id (and t_server.hostname) exactly
# Example: gpu-node-01
AGENT_HOSTNAME=gpu-node-01
