# Shared agent settings (deploy/env/common.env in this repo)
# Used by both account-provisioner and gpu-server-report.
# install.sh sets UPSTREAM_API_URL from REPORT_API_URL for account-provisioner.

# Report API base URL (no trailing slash)
REPORT_API_URL=http://localhost:8080

# Per-server derived PSK (hex). Run interactively on a secure admin machine:
#   ./gsad-backend/deploy/scripts/derive-agent-psk.sh gpu-node-01
# Do NOT put AGENT_MASTER_SECRET on GPU hosts — only this derived value.
AGENT_PSK=replace-with-derived-psk-for-this-server

# Required. Server id (must match X-Agent-Server-Id and JSON serverId)
AGENT_SERVER_ID=gpu-node-01
